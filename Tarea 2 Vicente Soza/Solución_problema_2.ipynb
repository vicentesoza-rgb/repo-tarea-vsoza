        "# lista de números del 1 al 100 que sean divisbles por 5\n",
        "lista_numeros = range(1,101)\n",
        "print(lista_numeros)\n",
        "\n",
        "for x in range(1,101):\n",
        "  if x % 10 == 0:\n",
        "    print(x, \"Bip Bip\")\n",
        "  elif x % 5 == 0:\n",
        "    print(x, \"Bip\")\n",
        ""
