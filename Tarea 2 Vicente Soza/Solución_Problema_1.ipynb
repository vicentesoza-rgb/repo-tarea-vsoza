      "source": [
        "# lista desde -30 al 50\n",
        "lista_numeros = range(-30,51)\n",
        "print(lista_numeros)\n",
        "\n",
        "for x in range(-30,51):\n",
        "  if(x < 0):\n",
        "    print(x, \"Muy frío\")\n",
        "  elif(x >= 0 and x <= 24):\n",
        "    print(x, \"Templado\")\n",
        "  else:\n",
        "    print(x, \"Caluroso\")"
      ],
